# MATLAB autosave / backup files
*.asv
*.m~
*.mlx~
*.slxc

# Generated MATLAB data and figures
*.mat
*.fig

# Generated results
results/data/*
results/figures/*

# Keep empty results folders
!results/data/.gitkeep
!results/figures/.gitkeep

# Logs / temporary files
*.log
*.tmp

# Editor folders
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db
